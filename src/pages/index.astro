---
import Base from '../layouts/Base.astro';
import ScrollSection from '../components/ScrollSection.svelte';
import ProportionalTimeline from '../components/ProportionalTimeline.svelte';
import FamilyEras from '../components/FamilyEras.svelte';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---

<Base title="Saga Seglbúða í Landbroti">

  <!-- ═══════════════════════════════════════════ -->
  <!-- HERO                                        -->
  <!-- ═══════════════════════════════════════════ -->
  <header class="hero">
    <h1>Saga Seglbúða</h1>
    <div class="hero-divider"></div>
    <p class="hero-subtitle">
      Bær í Landbroti, á hraunbrún Eldgjár, þar sem eldur skapaði landið
      og vatn gaf líf — frá selstöðu í klaustureign til forseta Alþingis.
    </p>
    <p class="hero-meta">63,727°N &nbsp;·&nbsp; 17,946°V &nbsp;·&nbsp; Skaftárhreppur</p>
  </header>


  <!-- ═══════════════════════════════════════════ -->
  <!-- I. NAFNIÐ                                   -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="act" id="nafn">
    <ScrollSection client:visible>
      <div class="act-header">
        <span class="act-number">I. þáttur</span>
        <h2 class="act-title">Nafnið</h2>
        <p class="act-subtitle">Selbúðir, Seglbúðir og festarhringurinn</p>
      </div>
    </ScrollSection>

    <ScrollSection client:visible>
      <h3>«selbudir» — 1343</h3>
      <p>
        Í máldaga Kirkjubæjarklausturs frá <span class="date-marker">1343</span> (DI II, bls. 781)
        er jörðin skráð sem <strong>«selbudir»</strong> meðal eigna klaustursins. Þetta er
        elsta þekkta skriflega heimildin um bæinn — 298 árum eldri en næst elsta skráningin.
      </p>
      <p>
        Nafnafræðilega er <em>sel-búðir</em> gagnsætt: <strong>sel</strong> (afréttarkofi)
        + <strong>búðir</strong> (skýli). Staðurinn var upphaflega selstöðu — sumarbústaður
        fjárhirða á afrétti.
      </p>
    </ScrollSection>

    <ScrollSection width="wide" client:visible>
      <figure class="figure figure-historical">
        <img src={`${base}facsimiles/diplomatarium-1343.png`}
             alt="Diplomatarium Islandicum II, bls. 781 — máldagi Kirkjubæjarklausturs 1343"
             loading="lazy" />
        <figcaption class="figure-caption">
          Diplomatarium Islandicum II, bls. 781. Máldagi Kirkjubæjarklausturs frá 1343
          þar sem «selbudir» er skráð meðal eignum klaustursins.
        </figcaption>
      </figure>
    </ScrollSection>

    <ScrollSection client:visible>
      <h3>Hljóðbreytingin: l → gl</h3>
      <p>
        Einhvern tíma milli 1343 og 1641 breyttist nafnið úr <strong>Selbúðir</strong>
        í <strong>Seglbúðir</strong>. Þegar nafnformið «Seglbúðir» birtist í
        visitunarskrá klaustursins <span class="date-marker">1641</span> er
        hljóðbreytingin <strong>l → gl</strong> þegar orðin — dæmi um innskotshljóð
        sem þekkist í íslensku. Árbók fornleifafélags 1923 komst að sömu niðurstöðu:
        «vafalaust afbökun úr upprunalega nafninu Selbúðir.»
      </p>
    </ScrollSection>

    <ScrollSection client:visible>
      <div class="name-evolution">
        <div class="name-stage">
          <span class="name-year">1343</span>
          <span class="name-form">Selbúðir</span>
          <span class="name-meaning">sel + búðir = selstöðu-skýli</span>
        </div>
        <div class="name-arrow">→</div>
        <div class="name-stage">
          <span class="name-year">1641</span>
          <span class="name-form">Seglbúðir</span>
          <span class="name-meaning">innskotshljóð: l → gl</span>
        </div>
      </div>
    </ScrollSection>

    <ScrollSection client:visible>
      <h3>Festarhringurinn</h3>
      <p>
        Þegar uppruni nafnsins gleymist spretta upp nýjar skýringar. Þrjár óháðar heimildir
        staðfesta að járnhringur var í bergi við Seglbúðir: Vísir (1941),
        frásögn Þórarins Helgasonar (SÁM 84/63–64, 1964), og örnefnalýsingin (1975).
      </p>
      <p>
        Hringurinn var við <strong>Steðja í Gili</strong> austan túnsins. Hann var fjarlægður
        á fyrri hluta 19. aldar og «notaður til smíða.» Sagnir sögðu að skip hafi verið fest
        við hann — en nafnið «selbudir» er 298 árum eldra og vísar til selstöðu, ekki skipa.
        Festarhringurinn er líklega sjálfstæð fornminja; nafnsagan dæmi um
        <strong>epiponímíu</strong>: skýring spunni af fornminjum sem þegar voru til staðar.
      </p>
    </ScrollSection>

    <ScrollSection client:visible>
      <h3>Þjóðaráttanir</h3>
      <p>
        Á 20. öld birtust a.m.k. þrjár kenningar um nafnið:
      </p>
      <ul>
        <li><strong>Skipalending</strong> (Tíminn 1957) — skipgengur áll frá sjó.</li>
        <li><strong>Fornar tjaldbyggingar</strong> (Morgunblaðið 1984) — «segl» vísi til segldúks.</li>
        <li><strong>Norsk sambærileg nöfn</strong> (Morgunblaðið 1964) — «Seglheimur» á þremur stöðum í Noregi.</li>
      </ul>
    </ScrollSection>

    <div class="section-divider"></div>
  </section>


  <!-- ═══════════════════════════════════════════ -->
  <!-- II. LANDIÐ                                  -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="act" id="land">
    <ScrollSection client:visible>
      <div class="act-header">
        <span class="act-number">II. þáttur</span>
        <h2 class="act-title">Landið</h2>
        <p class="act-subtitle">Eldur, hraun og vatn</p>
      </div>
    </ScrollSection>

    <ScrollSection client:visible>
      <p>
        Seglbúðir stendur á hraunbrún Eldgjárhrauns, á jaðri þess fornu hraunflæðis sem rann
        úr Eldgjá um <span class="date-marker">934</span> og skapaði landið sem byggt var á.
        Bærinn er einn af 19 jörðum Landbrots — héraðs í Vestur-Skaftafellssýslu, á milli
        Skaftár og Eldhrauns.
      </p>
    </ScrollSection>

    <ScrollSection client:visible>
      <h3>Þrjú hraun</h3>
      <p>
        Jón Jónsson jarðfræðingur (1910–2005), fæddur á Kársstöðum í Landbroti, greindi
        frá þremur hraunlögum í grein sinni «Þankabrot um Landbrot» (1995):
      </p>
      <ol>
        <li><strong>Eldra undirlagshraun</strong> — hugsanlega yfir 6.000 ára.</li>
        <li><strong>Eldgjárhraun (934±2 e.Kr.)</strong> — hraunið sem bæirnir standa á.</li>
        <li><strong>Skaftáreldahraun (1783)</strong> — Lakagígahraun sem lagði undir sig hluta Landbrotsins.</li>
      </ol>
      <p>
        Tvær borholur á landi Seglbúða (SB-01 og SB-02) mældu hraunþykkt 20–22 metra.
      </p>
    </ScrollSection>

    <ScrollSection client:visible>
      <h3>Landbrotshólar</h3>
      <p>
        Þegar Eldgjáhraunið rann yfir votlendi um 934 mynduðust <strong>Landbrotshólar</strong> —
        stærsta gervigígasvæði Íslands (~50 km², yfir 4.000 gervigígar). Gervigígarnir urðu til
        þegar 1.100°C hraun mætti grunnvatni og gufusprengingar breytti yfirborðinu í holu keilu.
        Sumir voru á sögulegum tíma notaðir sem skjól fyrir búfé.
      </p>
    </ScrollSection>

    <ScrollSection client:visible>
      <h3>Grenlækur</h3>
      <p>
        Grenlækur er um 30 km langur lindarlækur. Vatnið seytlar gegnum Eldgjáhraun og
        Skaftáreldahraun og kemur fram sem lindavatn. Í læknum veiðist sjóbirtingur, bleikja
        og stundum lax. Seglbúðasvæðið er 10 km langt með um 40 veiðilykkjur.
      </p>
      <p>
        <strong>Tröllshylur</strong> (örnefni nr. 51), um 400 m frá bænum, er lýst sem
        «gamall farvegur eftir stórfljót» — vitni um stórt fljót sem rann á þessum stað
        á fyrri tímum.
      </p>
    </ScrollSection>

    <ScrollSection client:visible>
      <h3>Jökulhlaup</h3>
      <p>
        Skaftá rennur gegnum Landbrot og ber jökulhlaup á um tveggja ára fresti, stundum
        með allt að 3.500 m³/s hámarksrennsli. Jökulhlaup hafa mótað landslag Landbrotsins
        og breytt árfarvegum í aldanna rás.
      </p>
    </ScrollSection>

    <div class="section-divider"></div>
  </section>


  <!-- ═══════════════════════════════════════════ -->
  <!-- III. FÓLKIÐ                                 -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="act" id="folk">
    <ScrollSection client:visible>
      <div class="act-header">
        <span class="act-number">III. þáttur</span>
        <h2 class="act-title">Fólkið</h2>
        <p class="act-subtitle">Átta fjölskyldur, þrjár aldir</p>
      </div>
    </ScrollSection>

    <ScrollSection client:visible>
      <p>
        Manntöl frá 1703 til 1920 skrá átta aðskildar fjölskyldur á Seglbúðum. Þetta eru ekki
        kynslóðir einnar ættar heldur mismunandi fjölskyldur sem komu, bjuggu og fóru — hver
        með sína sögu. Heimilið var á bilinu 6 til 20 manns, en aldrei tómt.
      </p>
    </ScrollSection>

    <ScrollSection width="wide" client:visible>
      <FamilyEras client:visible />
    </ScrollSection>

    <ScrollSection client:visible>
      <h3>Plágan og Tólfahringur</h3>
      <p>
        Pestfaraldurinn barst til Íslands haustið <span class="date-marker">1402</span> og stóð
        til páska 1404. Nálægt Landbroti, norðan við Búland, var forn sókn kölluð
        <strong>Tólfahringur</strong> — hringur 12 bæja sem eyðilagðist «að mestu í pláguni 1402»
        samkvæmt ferðalýsingu Sveins Pálssonar.
      </p>
      <p>
        Manntal 1703 sýnir Seglbúðir í fullri ábúð, 300 árum eftir pestina.
      </p>
    </ScrollSection>

    <ScrollSection client:visible>
      <h3>Skaftáreldar og Oddur</h3>
      <p>
        Skaftáreldar hófust <span class="date-marker">8. júní 1783</span> og stóðu í átta mánuði.
        Í Landbroti lagði hraunið undir sig Vaðhellu. Sr. Jón Steingrímsson flutti Eldmessuna
        20. júlí 1783 þegar hraunið var 2 km frá kirkjunni. 76 sóknarbörn hans létust á einu ári.
      </p>
    </ScrollSection>

    <ScrollSection client:visible>
      <div class="pull-quote">
        «Sagt er, að Oddur, sem hér bjó eftir móðuharðindi, hafi lifað á silungi, sem þar veiddist.»
        <cite>Örnefnalýsing Seglbúða, 1975 — um Oddsbúr (örnefni nr. 41), hylur í Grenlæk</cite>
      </div>
    </ScrollSection>

    <ScrollSection client:visible>
      <h3>Tapaðar heimildir</h3>
      <p>
        Jarðabók Árna Magnússonar og Páls Vídalíns (1702–1714) skráði allar jarðir landsins.
        Hluti hennar um Skaftafellssýslu <strong>brann í Kaupmannahafnarbruna 20. október
        1728</strong>. Engin afrit fundust. Færslan um Seglbúðir hefði innifalið jarðarmat,
        nöfn ábúenda, landamerki og athugasemdir um ástand jarðarinnar.
      </p>
    </ScrollSection>

    <ScrollSection client:visible>
      <h3>Uppboðið 1887–1891</h3>
      <p>
        Jörðin var auglýst til sölu í Þjóðólfi, Ísafoldu og Fjallkonunni sumarið
        <span class="date-marker">1887</span> á 1.200 kr. Verðið lækkaði í 1.050, loks 900 kr
        árið 1891 — merki um efnahagsþrengingar á svæðinu.
      </p>
    </ScrollSection>

    <ScrollSection client:visible>
      <h3>Helgi Jónsson og Gyðríður (1920–1949)</h3>
      <p>
        Helgi Jónsson (f. 1894, d. 22. maí 1949) var bóndi í 29 ár. Hann giftist Gyðríði
        Pálsdóttur (f. 1897, d. 1994, 97 ára) frá Þykkvabæ og sat í sveitarstjórn
        Kirkjubæjarhrepps. Helgi lést 55 ára gamall; Gyðríður hélt áfram búskap.
      </p>
    </ScrollSection>

    <ScrollSection client:visible>
      <h3>Jón Helgason — bóndi, kennari, forseti</h3>
    </ScrollSection>

    <ScrollSection width="wide" client:visible>
      <div class="portrait-section">
        <figure class="portrait">
          <img src={`${base}myndir/jon-helgason-althingi.jpg`}
               alt="Jón Helgason, forseti Alþingis 1979–1983"
               loading="lazy" />
          <figcaption>Jón Helgason (1931–2019). Mynd: Alþingi.</figcaption>
        </figure>
        <div class="portrait-text">
          <p>
            Jón Helgason (f. 4. október 1931) var yngstur fjögurra systkina Helga. Hann lauk
            stúdentsprófi <span class="date-marker">1950</span> og tók strax við bænum.
            Hann giftist Guðrúnu Þorkelsdóttur 1961.
          </p>
          <table class="compact-table">
            <tbody>
              <tr><td>1974–1995</td><td>Alþingismaður Suðurkjördæmis</td></tr>
              <tr><td><strong>1979–1983</strong></td><td><strong>Forseti Alþingis</strong></td></tr>
              <tr><td>1983–1988</td><td>Ráðherra dóms- og landbúnaðarmála</td></tr>
            </tbody>
          </table>
          <p>
            Hann hlaut Stórskjaldarriddara Fálkaorðunnar (1981) og var allan tímann skráður
            í Seglbúðum sem lögheimili.
          </p>
        </div>
      </div>
    </ScrollSection>

    <ScrollSection client:visible>
      <div class="pull-quote">
        «Seglbúðir eru meðal glæsilegustu bændabýla á Íslandi, mikil ræktun, vel húsað og frábær snyrtimennska.»
        <cite>Tíminn, 9. ágúst 1972</cite>
      </div>
    </ScrollSection>

    <ScrollSection client:visible>
      <p>
        En Jón var ekki aðeins stjórnmálamaður. Hann er aðalheimildarmaður örnefnaskrár
        Seglbúða (1975), höfundur «Gamlar götur í Landbroti» (2000), og ritaði <em>Faðir
        minn — bóndinn</em> (1975) um föður sinn. Alls eru <strong>86 staðfest örnefni</strong>
        á landi jarðarinnar, frá Markskeri í norðri til Klofakletts í Fljótsbotn. Án hans hefði
        stór hluti þeirrar þekkingar sem þessi skýrsla byggir á glatast.
      </p>
    </ScrollSection>

    <div class="section-divider"></div>
  </section>


  <!-- ═══════════════════════════════════════════ -->
  <!-- IV. KORTIN                                  -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="act" id="kort">
    <ScrollSection client:visible>
      <div class="act-header">
        <span class="act-number">IV. þáttur</span>
        <h2 class="act-title">Kortin</h2>
        <p class="act-subtitle">Frá fyrsta striki til nákvæmrar kortlagningar</p>
      </div>
    </ScrollSection>

    <ScrollSection client:visible>
      <p>
        Seglbúðir kemur fram á a.m.k. tveimur sögulegum kortum. Saman segja þau sögu
        kortagerðar á Íslandi — frá hinu stóra yfirliti til nákvæmrar hernaðarkortlagningar.
      </p>
    </ScrollSection>

    <ScrollSection width="wide" client:visible>
      <figure class="figure figure-historical">
        <div class="map-year-badge">1844</div>
        <img src={`${base}kort/gunnlaugsson-1844-landbrot.jpg`}
             alt="Björn Gunnlaugsson kort af Landbroti, 1844"
             loading="lazy" />
        <figcaption class="figure-caption">
          <strong>Uppdráttur Íslands</strong> eftir Björn Gunnlaugsson (1844, 1:480.000).
          Fyrsta kortið sem sýnir Landbrot. Seglbúðir kemur fram sem bæjardottur á hraunbrúninni.
        </figcaption>
      </figure>
    </ScrollSection>

    <ScrollSection width="wide" client:visible>
      <figure class="figure figure-historical">
        <div class="map-year-badge">1905</div>
        <img src={`${base}kort/herforingjaradskort-1905-seglbudir.png`}
             alt="Dönsk herforingjaráðskort af Seglbúðum, 1905–1915"
             loading="lazy" />
        <figcaption class="figure-caption">
          <strong>Dönsku herforingjaráðskortin</strong> (1905–1915, 1:50.000).
          Seglbúðir er nafngreint með bæjartákni. Grænlækur (Grenlækur) rennur beint við bæinn.
          Héraðsheitið LANDBROT prentað yfir svæðið.
        </figcaption>
      </figure>
    </ScrollSection>

    <ScrollSection width="wide" client:visible>
      <figure class="figure figure-historical">
        <img src={`${base}kort/herforingjaradskort-1905-landbrot.png`}
             alt="Dönsk herforingjaráðskort af Landbroti, yfirlitsmynd"
             loading="lazy" />
        <figcaption class="figure-caption">
          Landbrot í víðara samhengi á herforingjaráðskortinu. Skaftá að austan,
          Landbrotshólar (gervigígar) og Landbrotsvötn sýnileg.
        </figcaption>
      </figure>
    </ScrollSection>

    <div class="section-divider"></div>
  </section>


  <!-- ═══════════════════════════════════════════ -->
  <!-- V. TÍMALÍNA                                 -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="act" id="timalina">
    <ScrollSection client:visible>
      <div class="act-header">
        <span class="act-number">Tímalína</span>
        <h2 class="act-title">934 — 1979</h2>
        <p class="act-subtitle">Frá Eldgjá til forseta Alþingis</p>
      </div>
    </ScrollSection>

    <ScrollSection client:visible>
      <p class="timeline-intro">
        Vegalengd milli atburða sýnir raunverulegan tíma.
        Fyrstu fjórar aldirnar eru þögular — enginn veit með vissu hvort
        fólk bjó á Seglbúðum á þeim tíma. Svo birtist nafnið «selbudir» árið 1343,
        og smám saman mótast sagan.
      </p>
    </ScrollSection>

    <ProportionalTimeline client:visible />
  </section>


  <!-- ═══════════════════════════════════════════ -->
  <!-- FOOTER                                      -->
  <!-- ═══════════════════════════════════════════ -->
  <footer class="site-footer">
    <p>Sögurannsókn unnin 2026. Byggð á heimildum, manntölum, örnefnaskrám, fræðigreinum og tímaritsgreinum.</p>
  </footer>

</Base>
